# Environment variables
# Copy to .env and fill in values before running

# Tauri development host (set automatically by Tauri CLI during dev)
# TAURI_DEV_HOST=

# Override the Vite module cache directory (defaults to node_modules/.vite)
# VITE_CACHE_DIR=node_modules/.vite

# Maximum allowed memory delta in MB for memory smoke tests (defaults to 10)
# MEMORY_MAX_DELTA_MB=10

# NODE_ENV=development
