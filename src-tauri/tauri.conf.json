{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FreelanceInvoice",
  "version": "0.1.0",
  "identifier": "com.freelanceinvoice.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FreelanceInvoice",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: customprotocol: data: blob:; img-src 'self' asset: data: blob: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
